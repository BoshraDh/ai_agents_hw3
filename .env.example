# -------------------------------------------------------
# LLM Provider — set ONE of the following
# -------------------------------------------------------

# OpenAI (default, recommended for CrewAI)
OPENAI_API_KEY=your_openai_api_key_here

# Anthropic (alternative)
# ANTHROPIC_API_KEY=your_anthropic_api_key_here

# -------------------------------------------------------
# Model selection (optional — CrewAI defaults to gpt-4o)
# -------------------------------------------------------
# OPENAI_MODEL_NAME=gpt-4o

# -------------------------------------------------------
# Search tool (required if Researcher Agent uses WebSearch)
# Get a free key at: https://serper.dev
# -------------------------------------------------------
# SERPER_API_KEY=your_serper_api_key_here

# -------------------------------------------------------
# CrewAI telemetry (optional — set to false to disable)
# -------------------------------------------------------
# CREWAI_TELEMETRY=false
